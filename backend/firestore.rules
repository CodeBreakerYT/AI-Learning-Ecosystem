rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write their own profile doc
    // (lastLogin, chosen headset, displayName/about/photoURL/email, etc.)
    // written by authState.js / vrSetup.js / profile.js.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Append-only login history written by authState.js. Users can create
    // their own log rows but never read or modify existing ones from the client.
    match /loginLogs/{logId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read, update, delete: if false;
    }
  }
}
